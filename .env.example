# ── Containly configuration ───────────────────────────────────────────────────
# Copy this file to `.env` and adjust it. NEVER commit your real .env.
# With the provided docker-compose.yml this file is loaded via `env_file: .env`,
# so ALL app configuration lives here (not in docker-compose.yml).

# HTTP port of the backend (also serves the built frontend).
# If you change this, also update the "ports:" mapping in docker-compose.yml.
PORT=8420

# Bind address inside the container. Leave 0.0.0.0.
HOST=0.0.0.0

# Secure cookies. Behind a TLS-terminating reverse proxy: true.
# IMPORTANT: keep "false" when reaching Containly over plain HTTP
# (e.g. http://<server-ip>:8420). With "true" over HTTP the browser upgrades all
# assets to HTTPS — which isn't served — and you get a BLANK/BLACK page.
CONTAINLY_SECURE_COOKIES=false

# Trust X-Forwarded-* headers (keep true behind a reverse proxy).
CONTAINLY_TRUST_PROXY=true

# Log level: fatal|error|warn|info|debug|trace
LOG_LEVEL=info

# Session secret. Leave unset → generated on first start and persisted in /data.
# Only set it to manage it externally (then >= 32 random bytes, base64/hex).
# CONTAINLY_SESSION_SECRET=

# ── Advanced (usually leave unset in the container) ───────────────────────────
# Data / stacks directories. In the container these default to /data and /stacks
# (the mounted volumes) — DO NOT set them to ./data here or data won't persist.
# Only relevant for local `npm run dev` (defaults: ./data and ./stacks).
# CONTAINLY_DATA_DIR=/data
# CONTAINLY_STACKS_DIR=/stacks
