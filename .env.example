# ── Containly server configuration ────────────────────────────────────────────
# Copy this file to `.env` and adjust it. NEVER commit your real .env.

# HTTP port of the backend (also serves the built frontend)
PORT=8420

# Bind address. Behind a reverse proxy usually 127.0.0.1 or the container network.
HOST=0.0.0.0

# Path to the SQLite database (users, sessions, endpoints, audit log)
CONTAINLY_DATA_DIR=./data

# Directory where Compose stacks live as files (version-controllable, no DB lock-in)
CONTAINLY_STACKS_DIR=./stacks

# Session secret. LEAVE EMPTY → generated on first start and persisted in data/.
# Only set this to manage it externally (then >= 32 random bytes, base64/hex).
# CONTAINLY_SESSION_SECRET=

# Sets the Secure flag on session cookies AND (behind TLS) enables HSTS +
# upgrade-insecure-requests.
# IMPORTANT: keep this "false" when you reach Containly over plain HTTP
# (e.g. http://<server-ip>:8420). With "true" over HTTP the browser upgrades all
# assets to HTTPS — which isn't served — and you get a BLANK/BLACK page.
# Set it to "true" ONLY when a reverse proxy terminates HTTPS in front of Containly.
CONTAINLY_SECURE_COOKIES=false

# Trust X-Forwarded-* headers (required behind a reverse proxy)
CONTAINLY_TRUST_PROXY=true

# Local Docker socket. See the README for least-privilege guidance.
DOCKER_SOCKET=/var/run/docker.sock

# Log level: fatal|error|warn|info|debug|trace
LOG_LEVEL=info
